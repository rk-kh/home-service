<%- include('../partials/header', { title: title }) %>

<div class="admin-dashboard container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4 admin-dashboard-header">
    <div>
      <h2 class="dashboard-title mb-1">Admin Dashboard</h2>
      <p class="text-muted mb-0">Logged in as <strong><%= user.name %></strong> — Administrator</p>
    </div>
    <div class="dashboard-actions">
      <a href="/admin/bookings" class="btn btn-outline-primary btn-sm me-2">Bookings</a>
      <a href="/admin/users" class="btn btn-outline-secondary btn-sm">Users</a>
    </div>
  </div>

  <div class="row g-3 mb-4 stats-cards">
    <div class="col-sm-6 col-xl-3">
      <div class="stat-card shadow-sm rounded-4 p-4 bg-white">
        <div class="stat-card-icon bg-primary text-white">
          <i class="bi bi-people-fill"></i>
        </div>
        <h5 class="stat-value mb-1"><%= totalUsers %></h5>
        <p class="stat-label mb-0">Total Users</p>
      </div>
    </div>
    <div class="col-sm-6 col-xl-3">
      <div class="stat-card shadow-sm rounded-4 p-4 bg-white">
        <div class="stat-card-icon bg-success text-white">
          <i class="bi bi-calendar-check-fill"></i>
        </div>
        <h5 class="stat-value mb-1"><%= totalBookings %></h5>
        <p class="stat-label mb-0">Total Bookings</p>
      </div>
    </div>
    <div class="col-sm-6 col-xl-3">
      <div class="stat-card shadow-sm rounded-4 p-4 bg-white">
        <div class="stat-card-icon bg-warning text-white">
          <i class="bi bi-hourglass-split"></i>
        </div>
        <h5 class="stat-value mb-1"><%= pendingBookings %></h5>
        <p class="stat-label mb-0">Pending</p>
      </div>
    </div>
    <div class="col-sm-6 col-xl-3">
      <div class="stat-card shadow-sm rounded-4 p-4 bg-white">
        <div class="stat-card-icon bg-info text-white">
          <i class="bi bi-patch-check-fill"></i>
        </div>
        <h5 class="stat-value mb-1"><%= confirmedBookings %></h5>
        <p class="stat-label mb-0">Confirmed</p>
      </div>
    </div>
  </div>

  <div class="card recent-bookings-card shadow-sm rounded-4">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h4 class="card-title mb-1">Recent Bookings</h4>
          <p class="text-muted mb-0">Latest customer requests and booking status overview.</p>
        </div>
        <a href="/bookings" class="btn btn-outline-primary btn-sm">View All</a>
      </div>

      <div class="table-responsive">
        <table class="table align-middle mb-0 admin-bookings-table">
          <thead class="table-light">
            <tr>
              <th>Customer</th>
              <th>Email</th>
              <th>Service</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% recentBookings.forEach(function(b){ %>
              <tr>
                <td><%= b.name %></td>
                <td><%= b.email %></td>
                <td><%= b.service %></td>
                <td>
                  <span class="status-badge status-<%= b.status.toLowerCase() %>"><%= b.status %></span>
                </td>
                <td><%= b.createdAt.toLocaleDateString('en-GB') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
