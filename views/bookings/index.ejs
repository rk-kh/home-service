<%- include('../partials/header') %>

<div class="container py-5">

  <!-- Dashboard Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h3 class="fw-bold mb-0">My Bookings</h3>
      <p class="text-muted small mb-0">Welcome back, <strong><%= user.name %></strong></p>
    </div>
    <a href="/bookings/create" class="btn btn-primary">
      <i class="bi bi-plus-circle me-1"></i> New Booking
    </a>
  </div>

  <!-- Bookings Table -->
  <% if (bookings.length === 0) { %>

    <!-- Empty State -->
    <div class="text-center py-5">
      <i class="bi bi-calendar-x text-muted" style="font-size:3rem;"></i>
      <h5 class="mt-3 text-muted">No bookings yet</h5>
      <p class="text-muted small">Click "New Booking" to book your first service.</p>
      <a href="/bookings/create" class="btn btn-primary mt-2">Book a Service</a>
    </div>

  <% } else { %>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-primary">
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Service</th>
                <th>Phone</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% bookings.forEach(function(booking, index) { %>
              <tr>
                <td class="text-muted small"><%= index + 1 %></td>
                <td class="fw-medium"><%= booking.name %></td>
                <td><%= booking.service %></td>
                <td><%= booking.phone %></td>
                <td>
                  <!-- Color the badge based on status -->
                  <span class="badge
                    <%= booking.status === 'Confirmed'  ? 'bg-success'  :
                        booking.status === 'Completed'  ? 'bg-secondary' :
                        booking.status === 'Cancelled'  ? 'bg-danger'   : 'bg-warning text-dark' %>">
                    <%= booking.status %>
                  </span>
                </td>
                <td class="text-muted small">
                  <%= booking.createdAt.toLocaleDateString('en-PK') %>
                </td>
                <td>
                  <!-- Edit Button -->
                  <a href="/bookings/edit/<%= booking._id %>" class="btn btn-sm btn-outline-primary me-1">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <!-- Delete Button -->
                  <a href="/bookings/delete/<%= booking._id %>"
                     onclick="return confirm('Are you sure you want to delete this booking?')"
                     class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i>
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  <% } %>

</div>

<%- include('../partials/footer') %>
