<%- include('partials/header') %>

<div class="page-header text-white text-center py-5">
  <div class="container">
    <h2 class="fw-bold mb-1"><i class="bi bi-tools me-2"></i>Our Services</h2>
    <p class="mb-0 opacity-75">Choose a service and book in minutes</p>
  </div>
</div>

<section class="py-5 bg-light">
  <div class="container">

    <% if (services.length === 0) { %>
      <div class="alert alert-info text-center">No services in database yet.</div>
    <% } else { %>
    <div class="row g-4">
      <% services.forEach(function(service) { %>
      <div class="col-md-6 col-lg-4">
        <div class="card service-card h-100 border-0 shadow-sm">
          <img src="<%= service.image %>" class="card-img-top service-img" alt="<%= service.name %>">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-semibold"><%= service.name %></h5>
            <p class="card-text text-muted small flex-grow-1"><%= service.description %></p>
            <p class="text-primary fw-semibold small mb-3"><i class="bi bi-tag me-1"></i><%= service.price %></p>
            <a href="/bookings/create" class="btn btn-primary w-100">
              <i class="bi bi-calendar-plus me-1"></i> Book Now
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

  </div>
</section>

<%- include('partials/footer') %>
