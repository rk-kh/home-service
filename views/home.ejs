<%- include('partials/header') %>

<!-- Hero (Enhanced) -->
<section class="hero-advanced text-white py-5 position-relative overflow-hidden">
  <div class="hero-bg" style="background-image: url('https://images.unsplash.com/photo-1580587771525-78b9dba3b914?w=1600&q=80');"></div>

  <div class="container py-5">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-4 mb-lg-0">
        <h1 class="display-5 fw-bold mb-3 hero-title">Home Services At Your Doorstep</h1>
        <p class="lead mb-4 opacity-85 hero-sub">Book trusted professionals for AC repair, plumbing, electrical work and more. Fast, affordable and reliable.</p>
        <a href="/services" class="btn btn-warning btn-lg fw-semibold me-2">
          <i class="bi bi-tools me-1"></i> Our Services
        </a>
        <a href="/auth/signup" class="btn btn-outline-light btn-lg">
          <i class="bi bi-person-plus me-1"></i> Get Started
        </a>

        <div class="mt-4 d-none d-md-flex gap-3">
          <div class="mini-card p-2 rounded-3 bg-white text-dark shadow-sm">
            <i class="bi bi-shield-check-fill text-primary"></i>
            <small class="d-block">Verified Pros</small>
          </div>
          <div class="mini-card p-2 rounded-3 bg-white text-dark shadow-sm">
            <i class="bi bi-clock-history text-primary"></i>
            <small class="d-block">Fast Response</small>
          </div>
          <div class="mini-card p-2 rounded-3 bg-white text-dark shadow-sm">
            <i class="bi bi-star-fill text-warning"></i>
            <small class="d-block">Top Rated</small>
          </div>
        </div>
      </div>

      <div class="col-lg-6 position-relative">
        <div class="blob mx-auto shadow-lg"></div>

        <div id="serviceCarousel" class="carousel slide service-carousel" data-bs-ride="carousel">
          <div class="carousel-inner rounded-4 overflow-hidden">
            <div class="carousel-item active">
              <img src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=700&q=80" class="d-block w-100" alt="Home Cleaning">
              <!-- <div class="carousel-caption d-none d-md-block">
                <h5>Home Cleaning</h5>
                <p class="small">Deep cleaning for a spotless home.</p>
              </div> -->
            </div>
            <div class="carousel-item">
              <img src="https://images.unsplash.com/photo-1676210134188-4c05dd172f89?w=700&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8cGx1bWJpbmd8ZW58MHx8MHx8fDA%3D" class="d-block w-100" alt="Plumbing">
              <!-- <div class="carousel-caption d-none d-md-block">
                <h5>Plumbing</h5>
                <p class="small">Quick fixes and full bathroom services.</p>
              </div> -->
            </div>
            <div class="carousel-item">
              <img src="https://images.unsplash.com/photo-1639776738932-956082f0b704?w=700&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTV8fG1vYmlsZSUyMHJlcGFpcnxlbnwwfHwwfHx8MA%3D%3D" class="d-block w-100" alt="Electrician">
              <!-- <div class="carousel-caption d-none d-md-block">
                <h5>Electrician</h5>
                <p class="small">Certified electricians for safe repairs.</p>
              </div> -->
            </div>
          </div>
        </div>

        <!-- Floating icons -->
        <div class="float-icon icon-1"><i class="bi bi-tools"></i></div>
        <div class="float-icon icon-2"><i class="bi bi-droplet-half"></i></div>
        <div class="float-icon icon-3"><i class="bi bi-lightning-charge-fill"></i></div>
      </div>
    </div>
  </div>

  <!-- subtle SVG wave at bottom -->
  <svg class="hero-wave" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 100" preserveAspectRatio="none">
    <path fill="#ffffff" d="M0,32 C180,96 360,0 720,32 C1080,64 1260,0 1440,32 L1440 100 L0 100 Z"></path>
  </svg>
</section>

<!-- Stats -->
<section class="bg-white py-4 border-bottom">
  <div class="container">
    <div class="row text-center gy-3">
      <div class="col-6 col-md-3">
        <h3 class="fw-bold text-primary mb-0">5,000+</h3>
        <small class="text-muted">Happy Customers</small>
      </div>
      <div class="col-6 col-md-3">
        <h3 class="fw-bold text-primary mb-0">200+</h3>
        <small class="text-muted">Expert Workers</small>
      </div>
      <div class="col-6 col-md-3">
        <h3 class="fw-bold text-primary mb-0">6</h3>
        <small class="text-muted">Service Types</small>
      </div>
      <div class="col-6 col-md-3">
        <h3 class="fw-bold text-primary mb-0">4.8 ★</h3>
        <small class="text-muted">Rating</small>
      </div>
    </div>
  </div>
</section>

<!-- Featured Services -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="fw-bold">Popular Services</h2>
      <p class="text-muted">Most booked services this month</p>
    </div>

    <% if (services.length === 0) { %>
      <div class="alert alert-info text-center">
        No services found. <a href="#">Seed the database</a> to add services.
      </div>
    <% } else { %>
    <div class="row g-4">
      <% services.forEach(function(service) { %>
      <div class="col-md-4">
        <div class="card service-card h-100 border-0 shadow-sm">
          <img src="<%= service.image %>" class="card-img-top service-img" alt="<%= service.name %>">
          <div class="card-body">
            <h5 class="card-title fw-semibold"><%= service.name %></h5>
            <p class="card-text text-muted small"><%= service.description %></p>
            <p class="text-primary fw-semibold small"><i class="bi bi-tag me-1"></i><%= service.price %></p>
            <% if (typeof user !== 'undefined' && user) { %>
              <a href="/bookings/create?service=<%= encodeURIComponent(service.name) %>" class="btn btn-primary btn-sm w-100">Book Now</a>
            <% } else { %>
              <a href="/auth/login" class="btn btn-primary btn-sm w-100">Book Now</a>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <div class="text-center mt-4">
      <a href="/services" class="btn btn-outline-primary px-4">View All Services &rarr;</a>
    </div>
  </div>
</section>

<!-- Why Us -->
<section class="py-5 bg-white">
  <div class="container">
    <h2 class="fw-bold text-center mb-4">Why Choose HomeServe?</h2>
    <div class="row g-4 text-center">
      <div class="col-md-4">
        <i class="bi bi-shield-check text-primary" style="font-size:2.5rem;"></i>
        <h5 class="fw-semibold mt-3">Verified Professionals</h5>
        <p class="text-muted small">All workers are background-checked before joining.</p>
      </div>
      <div class="col-md-4">
        <i class="bi bi-cash-coin text-primary" style="font-size:2.5rem;"></i>
        <h5 class="fw-semibold mt-3">Transparent Pricing</h5>
        <p class="text-muted small">No hidden charges. Clear price before you book.</p>
      </div> //there is problem in home page service card when user click on book now button it will redirect to login page even user already login so we need to check if user is login or not if user is login then it will redirect to booking page otherwise it will redirect to login page
      <div class="col-md-4">
        <i class="bi bi-clock text-primary" style="font-size:2.5rem;"></i>
        <h5 class="fw-semibold mt-3">Fast Response</h5>
        <p class="text-muted small">Professional at your door within 1 hour.</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
